<!DOCTYPE html>
<html lang="no">
<head>
<meta charset="UTF-8"/>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #F4F5F0; font-family: 'Syne', sans-serif; display: flex; flex-direction: column; gap: 0; }
  :root { --blue: #3399FF; --violet: #6A6AFF; --dark: #1A1A1A; }

  .option { padding: 4rem 5rem; border-bottom: 1px solid rgba(0,0,0,0.08); display: flex; align-items: center; gap: 4rem; }
  .option:last-child { border-bottom: none; }
  .opt-label { min-width: 180px; }
  .opt-num { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: #3399FF; margin-bottom: 0.5rem; }
  .opt-name { font-family: 'Syne', sans-serif; font-size: 1.1rem; font-weight: 800; color: #1A1A1A; line-height: 1.2; margin-bottom: 0.4rem; }
  .opt-desc { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: #7A7B8A; line-height: 1.6; }
  .preview { font-family: 'Syne', sans-serif; font-size: 8rem; font-weight: 800; line-height: 1; letter-spacing: -0.03em; }

  /* OPTION 1: Character scramble — letters cycle through random chars before landing */
  .scramble { color: #1A1A1A; cursor: default; }

  /* OPTION 2: Animated gradient flowing through solid letters */
  .flowing {
    background: linear-gradient(90deg, #1A1A1A 0%, #3399FF 30%, #6A6AFF 50%, #3399FF 70%, #1A1A1A 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: flow 3s linear infinite;
  }
  @keyframes flow { to { background-position: 200% center; } }

  /* OPTION 3: Terminal cursor — "AI" on dark bg with blinking cursor and bracket framing */
  .terminal-wrap { background: #1A1A1A; border-radius: 10px; padding: 1.5rem 2.5rem; display: inline-flex; align-items: baseline; gap: 0; position: relative; }
  .terminal-wrap::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 28px; background: rgba(255,255,255,0.04); border-radius: 10px 10px 0 0; }
  .terminal-dots { position: absolute; top: 9px; left: 14px; display: flex; gap: 5px; }
  .terminal-dots span { width: 8px; height: 8px; border-radius: 50%; }
  .terminal-dots span:nth-child(1) { background: #FF5F57; }
  .terminal-dots span:nth-child(2) { background: #FEBC2E; }
  .terminal-dots span:nth-child(3) { background: #28C840; }
  .t-prompt { font-family: 'JetBrains Mono', monospace; font-size: 1.8rem; color: #3399FF; margin-right: 0.3em; font-weight: 400; }
  .terminal-text { background: linear-gradient(135deg, #3399FF, #6A6AFF); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .t-cursor { display: inline-block; width: 0.55em; height: 0.85em; background: #6A6AFF; margin-left: 0.1em; vertical-align: -0.05em; animation: blink 1.1s step-end infinite; border-radius: 2px; }
  @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: 0; } }
</style>
</head>
<body>

<!-- OPTION 1: Scramble -->
<div class="option">
  <div class="opt-label">
    <div class="opt-num">// Alternativ 01</div>
    <div class="opt-name">Karakter­scramble</div>
    <div class="opt-desc">Bokstavene spinner<br>gjennom tilfeldige<br>tegn ved hover —<br>lander på "AI"</div>
  </div>
  <div class="preview scramble" id="scramble" onmouseenter="startScramble()">AI</div>
</div>

<!-- OPTION 2: Flowing gradient -->
<div class="option">
  <div class="opt-label">
    <div class="opt-num">// Alternativ 02</div>
    <div class="opt-name">Flytende gradient</div>
    <div class="opt-desc">Mørk-til-blå gradient<br>beveger seg kontinuer­lig<br>gjennom bokstavene —<br>subtil og elegant</div>
  </div>
  <div class="preview flowing">AI</div>
</div>

<!-- OPTION 3: Terminal -->
<div class="option">
  <div class="opt-label">
    <div class="opt-num">// Alternativ 03</div>
    <div class="opt-name">Terminal</div>
    <div class="opt-desc">Mørk terminal-boks<br>med prompt-symbol<br>og blinkende cursor —<br>tydelig tech-estetikk</div>
  </div>
  <div class="terminal-wrap">
    <div class="terminal-dots"><span></span><span></span><span></span></div>
    <span class="t-prompt">$_</span>
    <span class="preview terminal-text">AI</span>
    <span class="t-cursor"></span>
  </div>
</div>

<script>
const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#%&';
const target = 'AI';
let frame = 0;
let interval = null;

function startScramble() {
  if (interval) return;
  const el = document.getElementById('scramble');
  let iter = 0;
  interval = setInterval(() => {
    el.textContent = target.split('').map((c, i) => {
      if (i < iter) return target[i];
      return chars[Math.floor(Math.random() * chars.length)];
    }).join('');
    if (iter >= target.length) {
      clearInterval(interval);
      interval = null;
      el.textContent = 'AI';
    }
    iter += 0.3;
  }, 40);
}
</script>
</body>
</html>
